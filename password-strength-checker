def check_password(password): # creates function (check_password) that inputs a password
    length = len(password)

    has_upper = any(c. isupper() for c in password) # any(...) = true if at least one is there
    has_lower = any(c. islower() for c in password) # c. islower = checks each one
    has_numb = any(c. isdigit() for c in password) # for c in password = loops through each caracter
    has_symb = any(not c. isalnum() for c in password) # not isalnum = neither a number or a letter

    score = 0 
    feedback = [] # empty "list"

    # caracteristics of a strong password
    if length >= 15:
        score += 1 
    else:
        feedback.append("The password should be at least 15 caracters.") # append() = adds a suggestion to the "list" to suggest later
    if has_upper:
        score+=1
    else:
        feedback.append("Add uppercase letters.")
    if has_lower:
        score+=1
    else:
        feedback.append("Add lowercase letters.")
    if has_numb:
        score+=1
    else:
        feedback.append("Add numbers.")
    if has_symb:
        score+=1
    else:
        feedback.append("Add  a special caracter.")
    
    return score, feedback # returns values to use

while True: #creates loop until reaches a strong password (break)
    password = input("Enter a password: ")
    score, feedback = check_password(password) 

    if score <=2:
        print("Weak password, please try again.\n")
    elif score == 3 or score == 4:
        print("Medium password, try to improve it.\n")
    else:
        print("Strong password!")
        break # stops loop

    print("Suggestions:")
    for f in feedback: # goes through suggestions in the "list"
        print("-", f)

    print() # adds a space between lines